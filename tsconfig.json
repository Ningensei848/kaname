{
	"compilerOptions": {
		"target": "ES2022",
		"module": "commonjs",
		"moduleResolution": "node",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"outDir": "./dist",
		"rootDir": "./",
		"incremental": true,
		"tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo"
	},
	"include": ["src/**/*", "tests/**/*"]
}

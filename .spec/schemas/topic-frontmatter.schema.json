{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://kaname.local/schemas/topic-frontmatter.schema.json",
	"title": "kaname topic Markdown frontmatter",
	"type": "object",
	"additionalProperties": false,
	"required": ["title", "tags", "source_ids", "updated"],
	"properties": {
		"title": {
			"type": "string",
			"minLength": 1
		},
		"aliases": {
			"type": "array",
			"items": {
				"type": "string",
				"minLength": 1
			}
		},
		"tags": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "string",
				"pattern": "^[a-z0-9_/-]+$",
				"minLength": 1
			}
		},
		"source_ids": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "string",
				"pattern": "^[a-z0-9_]+$",
				"minLength": 1
			}
		},
		"updated": {
			"type": "string",
			"format": "date"
		},
		"status": {
			"type": "string",
			"enum": ["draft", "published", "archived"]
		}
	}
}

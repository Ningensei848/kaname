{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://kaname.local/schemas/notification-state.schema.json",
	"title": "kaname external notification state",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"notified_deployment_ids",
		"notified_commit_hashes",
		"last_successful_notification_at",
		"last_failed_notification_at"
	],
	"properties": {
		"notified_deployment_ids": {
			"type": "array",
			"items": {
				"type": "string",
				"minLength": 1
			},
			"uniqueItems": true
		},
		"notified_commit_hashes": {
			"type": "array",
			"items": {
				"type": "string",
				"pattern": "^[0-9a-f]{7,64}$"
			},
			"uniqueItems": true
		},
		"last_successful_notification_at": {
			"type": ["string", "null"],
			"format": "date-time"
		},
		"last_failed_notification_at": {
			"type": ["string", "null"],
			"format": "date-time"
		}
	}
}

{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://kaname.local/schemas/discord-webhook-payload.schema.json",
	"title": "Kaname Discord deployment notification payload",
	"type": "object",
	"additionalProperties": false,
	"required": ["username", "avatar_url", "embeds"],
	"properties": {
		"username": { "type": "string", "const": "Aegis-Intelligence" },
		"avatar_url": { "type": "string", "format": "uri" },
		"embeds": {
			"type": "array",
			"minItems": 1,
			"maxItems": 1,
			"items": {
				"type": "object",
				"additionalProperties": false,
				"required": [
					"title",
					"description",
					"url",
					"color",
					"fields",
					"footer",
					"timestamp"
				],
				"properties": {
					"title": { "type": "string", "minLength": 1 },
					"description": { "type": "string", "minLength": 1 },
					"url": { "type": "string", "format": "uri" },
					"color": { "type": "integer", "minimum": 0 },
					"fields": {
						"type": "array",
						"minItems": 3,
						"items": {
							"type": "object",
							"additionalProperties": false,
							"required": ["name", "value", "inline"],
							"properties": {
								"name": { "type": "string", "minLength": 1 },
								"value": { "type": "string", "minLength": 1 },
								"inline": { "type": "boolean" }
							}
						}
					},
					"footer": {
						"type": "object",
						"additionalProperties": false,
						"required": ["text", "icon_url"],
						"properties": {
							"text": { "type": "string", "minLength": 1 },
							"icon_url": { "type": "string", "format": "uri" }
						}
					},
					"timestamp": { "type": "string", "format": "date-time" }
				}
			}
		}
	}
}

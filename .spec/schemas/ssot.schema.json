{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://kaname.local/schemas/ssot.schema.json",
	"title": "kaname SSoT source configuration",
	"type": "object",
	"additionalProperties": false,
	"required": ["ssot_sources"],
	"properties": {
		"ssot_sources": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "object",
				"additionalProperties": false,
				"required": ["id", "name", "url", "description"],
				"properties": {
					"id": {
						"type": "string",
						"pattern": "^[a-z0-9_]+$",
						"minLength": 1
					},
					"name": {
						"type": "string",
						"minLength": 1
					},
					"url": {
						"type": "string",
						"format": "uri"
					},
					"feed_url": {
						"type": "string",
						"format": "uri"
					},
					"description": {
						"type": "string",
						"minLength": 1
					},
					"meta_url": {
						"type": "string",
						"format": "uri"
					},
					"custom_extraction_instruction": {
						"type": "string"
					}
				}
			}
		}
	}
}

{
  "name": "kaname",
  "version": "1.0.0",
  "description": "Autonomous cybersecurity knowledge orchestrator",
  "main": "dist/orchestrator.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx src/orchestrator.ts",
    "build": "esbuild src/orchestrator.ts --bundle --platform=node --target=node20 --outfile=dist/orchestrator.js",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "test": "node --test tests/**/*.test.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "yaml": "^2.4.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "^20.12.12",
    "esbuild": "^0.21.3",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
